# Nutri - Self-Hosted Calorie Tracker
# Copy to .env and customize

# Security
JWT_SECRET=change-me-to-a-random-64-char-string

# USDA FoodData Central API Key (get free key at https://fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=DEMO_KEY

# OpenID Connect (optional)
OIDC_ENABLED=false
OIDC_DISCOVERY_URL=            # e.g. https://auth.example.com/.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=             # e.g. http://localhost:3000/oidc/callback
OIDC_SCOPES=openid email profile groups

# OIDC group → role mapping
OIDC_GROUPS_CLAIM=groups       # Name of the claim in the ID token that contains group names
OIDC_ADMIN_GROUP=              # Members of this group become admins (e.g. nutri-admins)
OIDC_USER_GROUP=               # If set, only members of this group (or admin group) can log in

# Port (the single entrypoint — nginx serves both UI and API)
FRONTEND_PORT=3000

# Admin account (optional — if set, auto-creates admin on first startup)
# If left empty, the web UI will prompt for admin setup on first visit.
ADMIN_USERNAME=
ADMIN_PASSWORD=
